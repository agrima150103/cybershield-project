{
  "manifest_version": 3,
  "name": "CyberShield - Threat Detector",
  "version": "1.0.0",
  "description": "Real-time warnings before visiting phishing or malicious websites",
  "permissions": ["activeTab", "storage", "webNavigation"],
  "host_permissions": ["http://localhost:5000/*"],
  "background": {
    "service_worker": "background/background.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "css": ["content/content.css"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}